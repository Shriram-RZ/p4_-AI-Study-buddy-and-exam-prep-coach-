# --- Backend env ---
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://studybuddy:studybuddy@localhost:5432/studybuddy

# JWT
JWT_SECRET=please-generate-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=10080
RESET_TOKEN_MINUTES=30

# Cookie
COOKIE_NAME=studybuddy_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.yourdomain.com

# CORS (comma-separated in production; here use Python list when overriding via .env)
CORS_ORIGINS=["http://localhost:3000"]

# Gemini Flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models

UPLOAD_MAX_MB=10
